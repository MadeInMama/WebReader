@model WebReader.Models.Dtos.AllScheduledTasksViewModel

<table>
    <thead>
    <tr>
        <th><h3>#</h3></th>
        <th><h3>Type</h3></th>
        <th><h3>Status</h3></th>
        <th><h3>Progress</h3></th>
        <th><h3>Result</h3></th>
        <th><h3>Start At</h3></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Items)
    {
        <tr onclick="openModalClicked(`<pre>${JSON.stringify(@(JsonSerializer.Serialize(item)), null, 2)}</pre>`)">
            <td>@($"{(int)item.Type}")</td>
            <td>@item.Type</td>
            <td>@item.Status</td>
            <td>
                <div>
                    <div class="progress-bar"></div>
                    <div progress="@((int)(item.Progress * 100))" progress-multiplier="47"
                         class="progress-bar-inner progress-bar-inner-linear"></div>
                    <div progress="@((int)(item.Progress * 100))"
                         class="progress-bar-inner progress-bar-inner-text">@((int)(item.Progress * 100))</div>
                </div>
            </td>
            <td>@item.Result</td>
            <td utc="'@item.HaveToStartAt'"
                class="to-local-date-time"></td>
        </tr>
    }
    </tbody>
</table>
