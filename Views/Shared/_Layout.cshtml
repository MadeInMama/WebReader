@using WebReader.Models
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover, maximum-scale=1.0"/>

    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="WebReader">
    <link rel="apple-touch-icon" href="~/images/icon-512.png">
    <link rel="manifest" href="~/manifest.json">

    <title>@ViewData["Title"] - WebReader</title>

    <link rel="shortcut icon" href="~/favicon.ico" type="image/x-icon"/>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/site-items.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/header.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/click-effects.css" asp-append-version="true"/>

    @await RenderSectionAsync("Style", false)
</head>
<body>

@Html.AntiForgeryToken()

<div id="safe-area-inset-top"></div>

<header class="can-be-opened opened">
    @await RenderSectionAsync("SpecialInfo", false)
    <nav>
        <ul>
            @if (User.Identity is { IsAuthenticated: true })
            {
                <li>
                    <a asp-controller="Home" asp-action="Index" class="click-effect">Home</a>
                </li>

                @if (User.GetUserRoles().Contains(RoleType.Admin))
                {
                    <li>
                        <a asp-controller="ScheduledTask" asp-action="ScheduledTasks" class="click-effect">Scheduled
                            Tasks</a>
                    </li>
                }

                <li>
                    <a asp-controller="File" asp-action="GetAllBuckets" class="click-effect">Buckets</a>
                </li>
            }

            @await RenderSectionAsync("HeaderMenuItems", false)

            @if (User.Identity is { IsAuthenticated: true })
            {
                <li>
                    <a asp-controller="File" asp-action="GetReading" class="click-effect">Reading</a>
                </li>
                <li style="display: none;">
                    <form asp-controller="Account"
                          asp-action="DeleteMe"
                          method="post"
                          style="display:inline;">
                        <input type="hidden" name="_method" value="DELETE"/>
                        <button type="submit" class="click-effect"
                                onclick="return confirm('⚠️ This will permanently delete your profile. Continue?');">
                            Delete Profile
                        </button>
                    </form>
                </li>
                <li>
                    <a asp-controller="Account" asp-action="Logout" class="click-effect">Logout</a>
                </li>
            }
            else
            {
                <li>
                    <a asp-controller="Account" asp-action="SignIn" class="click-effect">Sign in</a>
                </li>
                <li>
                    <a asp-controller="Account" asp-action="SignUp" class="click-effect">Sing up</a>
                </li>
            }
        </ul>
    </nav>
    <button class="header-toggle opened-trigger click-effect" target="header"></button>
</header>

<main>
    @RenderBody()
</main>

<footer>
    @await RenderSectionAsync("Footer", false)
</footer>

<div id="scroll-progress-bar"></div>

<div id="safe-area-inset-bottom"></div>

<script src="~/js/cache/cache.js" asp-append-version="true"></script>
<script src="~/js/window-height-setter.js" asp-append-version="true"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/custom-event.js" asp-append-version="true"></script>
<script src="~/js/custom-axios.js" asp-append-version="true"></script>
<script src="~/js/to-local-date-time.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", false)

<script>
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
            navigator.serviceWorker.register('/sw.js')
                .then(reg => console.log('Service Worker зарегистрирован!', reg))
                .catch(err => console.error('Ошибка регистрации SW:', err));
        });
    }

    document.addEventListener('touchstart', () => {
    }, {passive: true});
</script>
</body>
</html>
