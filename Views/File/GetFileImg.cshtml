@model WebReader.Models.Dtos.FileViewModel

@{
    ViewData["Title"] = Model.Title;
}

@section Style
{
    <link rel="stylesheet" href="~/css/file-common-preview.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/file-img-preview.css" asp-append-version="true"/>

    <style>
        .force-light-canvas {
            filter: none !important;
        }

        @@media (prefers-color-scheme: light) {
            .force-light-mode {
                display: none;
            }
        }
    </style>
}

@section SpecialInfo {
    <h3 class="special-info-big">@Model.Title @Model.CurrentPartName</h3>
}

<h3 class="special-info-small">@Model.Title @Model.CurrentPartName</h3>

@if (Model.NextPartId.HasValue)
{
    @section HeaderMenuItems {
        <li>
            <a asp-controller="File" asp-action="GetFile"
               asp-route-bucketId="@Model.BucketId" asp-route-fileId="@Model.NextPartId.Value">
                Next part
            </a>
        </li>
    }
}

<div class="img-container force-light-canvas">
    <img style="visibility:hidden; filter: none !important;" id="img-canvas" src="" alt="Content render error."/>
</div>

@section Footer
{
    <div class="controls">
        <div class="spacer controls-start">
            @await Html.PartialAsync("_FullscreenControl")
            <button class="force-light-mode"></button>
        </div>
        <div class="controls-center">
            <button disabled class="prev-page"></button>
            <span class="preview-page">0/0</span>
            <button disabled class="next-page"></button>
        </div>
        <div class="controls-end">
            <div class="event-output"></div>

            <select class="set-scale">
                <option value="0">fixed</option>
                <option value="25">25%</option>
                <option value="50">50%</option>
                <option value="75">75%</option>
                <option value="100">100%</option>
            </select>
        </div>
    </div>
}

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script type="module">
        const url = @Html.Raw(Json.Serialize($"/api/S3/GetFile?bucketId={Model.BucketId}&fileId={Model.FileId}"));
        const decodedString = url.replace(/\\u0026/g, '&')
        let pages = [];
        let currentPage = @Model.Page;
        let currentScale = @Model.Scale;
        let maxPage = 1;

        requestQueue.enqueue({
            method: 'POST',
            url: decodedString,
            data: {},
            options: {
                responseType: 'arraybuffer',
                headers: {
                    'RequestVerificationToken': GetAntiForgeryToken()
                },
                withCredentials: true
            },
            beforeSend: () => {
                customSendCurrPageEvent.detail.message = `<div class="progress-bar"></div><div progress="0" class="progress-bar-inner progress-bar-inner-linear">0</div>`;
                customSendCurrPageEvent.detail.type = EventTypes.INFINITE;
                targetElement.dispatchEvent(customSendCurrPageEvent);
            },
            setProgress: (val) => {
                Array.from(document.getElementsByClassName("progress-bar-inner")).forEach(value => {
                    value.setAttribute('progress', val);
                    value.innerHTML = val;
                });
            }
        })
            .then(async response => {
                await loadImages(response);
                customSendCurrPageEvent.detail.message = `<div class="success"></div>`;
                customSendCurrPageEvent.detail.type = EventTypes.FROM_MILLIS;
                customSendCurrPageEvent.detail.millis = 3000;
                targetElement.dispatchEvent(customSendCurrPageEvent);
            })
            .catch(_ => {
                customSendCurrPageEvent.detail.message = `<div class="error"></div>`;
                customSendCurrPageEvent.detail.type = EventTypes.INFINITE;
                targetElement.dispatchEvent(customSendCurrPageEvent);
            });

        async function loadImages(zip) {
            try {
                await parseImages(zip);
                maxPage = pages.length;
                SetPage(currentPage, false);
                SetScale(currentScale, false);
            } catch (err) {
                console.error('Failed to load ZIP:', err);
            }
        }

        function renderPage() {
            document.querySelector('#img-canvas').src = pages[currentPage - 1];
            document.querySelector('#img-canvas').style.visibility = 'visible';

            Array.from(document.getElementsByClassName("preview-page")).forEach(value => {
                value.textContent = `${currentPage}/${maxPage}`;
            });
        }

        async function parseImages(zip) {
            const zipFile = await new JSZip().loadAsync(zip);

            for (const img in zipFile.files) {
                const blob = await zipFile.files[img].async('blob');
                const imageUrl = URL.createObjectURL(blob);
                pages.push(imageUrl);
            }
        }

        Array.from(document.getElementsByClassName("prev-page")).forEach(value => {
            value.onclick = () => {
                SetPage(--currentPage);

                Array.from(document.getElementsByClassName("next-page")).forEach(value => {
                    value.disabled = false;
                });
            };
        });

        Array.from(document.getElementsByClassName("next-page")).forEach(value => {
            value.onclick = () => {
                SetPage(++currentPage);

                Array.from(document.getElementsByClassName("prev-page")).forEach(value => {
                    value.disabled = false;
                });
            };
        });

        Array.from(document.getElementsByClassName("set-scale")).forEach(value => {
            value.value = currentScale;

            value.onchange = (e) => {
                SetScale(e.target.value);
            };
        });

        function SetPage(page, send = true) {
            currentPage = clamp(page, 1, maxPage);

            if (currentPage === maxPage) {
                Array.from(document.getElementsByClassName("prev-page")).forEach(value => {
                    value.disabled = false;
                });
                Array.from(document.getElementsByClassName("next-page")).forEach(value => {
                    value.disabled = true;
                });
            } else if (currentPage === 1) {
                Array.from(document.getElementsByClassName("prev-page")).forEach(value => {
                    value.disabled = true;
                });
                Array.from(document.getElementsByClassName("next-page")).forEach(value => {
                    value.disabled = false;
                });
            } else {
                Array.from(document.getElementsByClassName("prev-page")).forEach(value => {
                    value.disabled = false;
                });
                Array.from(document.getElementsByClassName("next-page")).forEach(value => {
                    value.disabled = false;
                });
            }

            renderPage(currentPage);

            SetScale(currentScale, false);

            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });

            if (send) SendCurrPage();
        }

        function SetScale(scale, send = true) {
            currentScale = Number.parseInt(scale);

            Array.from(document.getElementsByClassName("set-scale")).forEach(value => {
                value.value = currentScale
            });

            if (currentScale === 0) {
                document.querySelector("main").classList.add("max-width-set");
                document.getElementById("img-canvas").style.maxWidth = "100%";
            } else {
                document.querySelector("main").classList.remove("max-width-set");
                document.getElementById("img-canvas").style.maxWidth = currentScale + "%";
            }

            if (send) SendCurrPage();
        }

        function clamp(value, min, max) {
            return Math.min(Math.max(value, min), max);
        }

        function SendCurrPage() {
            requestQueue.enqueue({
                method: 'POST',
                url: '/api/FileApi/UpdateReading',
                data: {
                    FileId: "@Model.FileId",
                    UserId: "@Model.UserId",
                    Page: currentPage,
                    Scale: currentScale,
                    IsLastPage: currentPage === maxPage,
                },
                options: {
                    headers: {
                        'RequestVerificationToken': GetAntiForgeryToken()
                    },
                    withCredentials: true
                },
                beforeSend: () => {
                    customSendCurrPageEvent.detail.message = `<div class="waiting"></div>`;
                    customSendCurrPageEvent.detail.type = EventTypes.INFINITE;
                    targetElement.dispatchEvent(customSendCurrPageEvent);
                }
            })
                .then(_ => {
                    customSendCurrPageEvent.detail.message = `<div class="success"></div>`;
                    customSendCurrPageEvent.detail.type = EventTypes.FROM_MILLIS;
                    customSendCurrPageEvent.detail.millis = 3000;
                    targetElement.dispatchEvent(customSendCurrPageEvent);
                })
                .catch(_ => {
                    customSendCurrPageEvent.detail.message = `<div class="error"></div>`;
                    customSendCurrPageEvent.detail.type = EventTypes.INFINITE;
                    targetElement.dispatchEvent(customSendCurrPageEvent);
                });
        }

        document.querySelector("button.force-light-mode").onclick = () => {
            document.querySelector(".img-container").classList.toggle("force-light-canvas");
        };
    </script>
}
