@model WebReader.Models.Dtos.AllFilesInBucketViewModel
@{
    ViewData["Title"] = "FILES";
}

@section Style
{
    <link rel="stylesheet" href="~/css/file-list.css" asp-append-version="true"/>
}

@section SpecialInfo
{
    @if (User.Identity is { IsAuthenticated: true })
    {
        <h3 class="special-info-big">Hello, @User.Identity.Name!</h3>
    }
}

<div id="full_content">
    <details open class="always-open-details">
        <summary>
            <span>@Model.BucketName</span>
        </summary>
        @foreach (var item in Model.Items)
        {
            <div class="item-line" id="@("RL_" + item.Id)">
                @if (item.IsParted)
                {
                    <div class="center parted secondary-info-span"></div>
                }
                else
                {
                    @if (item.IsReading)
                    {
                        <div class="center secondary-info-span @(item.IsDone ? "is-done" : "in-progress")"></div>
                    }
                    else
                    {
                        <div class="in-progress-empty secondary-info-span"></div>
                    }
                }

                @if (item.IsParted)
                {
                    <a asp-controller="File" asp-action="GetAllPartsInFile"
                       asp-route-bucketId="@Model.Id"
                       asp-route-fileId="@item.Id" class="click-effect">
                        <span class="left main-info-span importance-0">@item.FileName</span>
                        <span class="right secondary-info-span importance-1">@item.TotalCount</span>
                        <span class="right secondary-info-span importance-2">@FormatSize(item.TotalSize)</span>
                    </a>
                }
                else
                {
                    <a asp-controller="File" asp-action="GetFile"
                       asp-route-bucketId="@Model.Id"
                       asp-route-fileId="@item.Id" class="click-effect">
                        <span class="left main-info-span importance-0">@item.FileName</span>
                        <span class="right secondary-info-span importance-3">@item.Type?.ToLower()</span>
                        <span
                            class="right secondary-info-span importance-2 to-local-date"
                            utc="@item.DateTime.ToString("O")"></span>
                        <span class="right secondary-info-span importance-1">@FormatSize(item.Size)</span>
                    </a>
                }

                <div class="event-output">
                    @if (!item.IsParted)
                    {
                        <button class="download-file click-effect"
                                data-file-id="@item.Id" data-bucket-id="@Model.Id"></button>
                    }

                    @if (!item.IsParted)
                    {
                        <button class="remove click-effect"
                                onclick="Delete('@item.Id', '@item.FileName')"></button>
                    }
                </div>
            </div>
        }
    </details>
</div>
@await Html.PartialAsync("_EmptyDisplay")

@if (Model.IsBelongsToUser)
{
    <div class="upload-btn-container">
        <a class="btn" asp-controller="File"
           asp-action="UploadFile"
           asp-route-bucketId="@Model.Id">
            Upload File
        </a>
    </div>
}

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        const url = '/api/FileApi/DeleteFile';
        const lineSelector = '.item-line';
    </script>
    <script src="~/js/delete-row.js" asp-append-version="true"></script>
    <script src="~/js/empty-row-control.js" asp-append-version="true"></script>

    <script>
        CheckOnEmpty();
        convertUtcToLocal();
    </script>

    <script src="~/js/cache/file-cache.js" asp-append-version="true"></script>
    <script src="~/js/cache/file-download.js" asp-append-version="true"></script>
    <script>
        window.addEventListener("load", () => {
            Array.from(document.querySelectorAll(".download-file")).forEach(el => {
                new FileDownloadButton(el, el.dataset.bucketId, el.dataset.fileId);
            });
        });
    </script>
}
