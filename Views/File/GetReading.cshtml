@model WebReader.Models.Dtos.AllFilesReadingViewModel
@{
    ViewData["Title"] = "READING";
}

@section Style
{
    <link rel="stylesheet" href="~/css/file-list.css" asp-append-version="true"/>
    <style>
        summary > span {
            cursor: pointer;
            position: relative;
        }

        summary > span::after {
            position: absolute;
            content: "";
            width: 0;
            bottom: 0;
            left: 50%;
            height: 0.025em;
            display: block;
            background: var(--foreground-color);
            transition: 150ms;
        }

        summary > span:hover::after {
            width: 100%;
            left: 0;
        }

        @@media (hover: none) and (pointer: coarse) {
            summary > span:hover::after {
                display: none;
            }
        }

        .reading-line {
            padding-left: 2em;
        }

        .reading-line > a {
            justify-content: flex-start;
        }
    </style>
}

@section SpecialInfo {
    @if (User.Identity is { IsAuthenticated: true })
    {
        <h3 class="special-info-big">Hello, @User.Identity.Name!</h3>
    }
}

<div id="full_content">
    @foreach (var item in Model.Items)
    {
        <details open>
            <summary><span>@item.Key.CustomName</span></summary>
            @foreach (var obj in item.Value)
            {
                <div class="reading-line item-line" id="@("RL_" + obj.ReadingId)">
                    <a asp-controller="File" asp-action="GetFile"
                       asp-route-bucketId="@item.Key.BucketId"
                       asp-route-fileId="@obj.FileId">
                        <span>@obj.CustomName</span>
                        @if (obj.CurrentPartName != null)
                        {
                            <span class="importance-1">@obj.CurrentPartName</span>
                        }
                        <span class="importance-2">@obj.Page</span>
                    </a>
                    <div class="event-output">
                        <button class="remove"
                                onclick="Delete('@obj.ReadingId', '@obj.CustomName @obj.CurrentPartName')"></button>
                    </div>
                </div>
            }
        </details>
    }
</div>

@await Html.PartialAsync("_EmptyDisplay")

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        const url = '/api/FileApi/DeleteReading';
        const lineSelector = '.item-line';
    </script>
    <script src="~/js/delete-row.js"></script>
    <script src="~/js/empty-row-control.js"></script>
    <script>CheckOnEmpty()</script>
}
