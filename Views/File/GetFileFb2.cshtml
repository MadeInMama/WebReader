@model WebReader.Models.Dtos.FileViewModel

@{
    ViewData["Title"] = Model.Title;
}

@section Style
{
    <link rel="stylesheet" href="~/css/file-common-preview.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/file-fb2-preview.css" asp-append-version="true"/>
}

@section SpecialInfo
{
    <h3 class="special-info-big">@Model.Title</h3>
}

<h3 class="special-info-small">@Model.Title</h3>

@await Html.PartialAsync("_ModalInfoWithCustomHtml")

<div class="fb2-canvas-container">
</div>

@section Footer
{
    <div class="controls">
        <div class="spacer controls-start">
            @await Html.PartialAsync("_FullscreenControl")
        </div>
        <div class="controls-center">
            <button class="prev-page"></button>
            <span class="preview-page">0/0</span>
            <button class="next-page"></button>
        </div>
        <div class="spacer"></div>
        @*     <div class="controls-end"> *@
        @*         <select class="set-scale"> *@
        @*             <option value="0.5">0.5</option> *@
        @*             <option value="0.75">0.75</option> *@
        @*             <option value="1">1</option> *@
        @*             <option value="2">2</option> *@
        @*             <option value="3">3</option> *@
        @*             <option value="4">4</option> *@
        @*             <option value="5">5</option> *@
        @*         </select> *@
        @* </div> *@
    </div>
}

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script type="module">

        const url = @Html.Raw(Json.Serialize(Model.Url));
        const decodedString = url.replace(/\\u0026/g, '&')
        let pages = [];
        let currentPage = @Model.Page;
        let maxPage = 1;
        let imageMap = new Map();
        let noteMap = new Map();

        async function loadFB2(url) {
            try {
                const response = await fetch(url);
                const fb2Text = await response.text();
                parseFB2(fb2Text);
                maxPage = pages.length;
                SetPage(currentPage);
            } catch (err) {
                console.error('Failed to load FB2:', err);
            }
        }

        function renderPage() {
            document.querySelector('.fb2-canvas-container').innerHTML = pages[currentPage - 1];

            Array.from(document.getElementsByClassName("preview-page")).forEach(value => {
                value.textContent = `${currentPage}/${maxPage}`;
            });
        }

        loadFB2(decodedString);

        function parseFB2(xmlString) {
            const parser = new DOMParser();
            const doc = parser.parseFromString(xmlString, 'application/xml');
            if (doc.querySelector('parsererror')) {
                console.error('Invalid XML');
                return;
            }

            const sections = Array.from(doc.querySelectorAll("section"));

            const maxPCount = 6;

            sections.forEach(section => {
                const parts = Array.from(section.querySelectorAll(":scope > *"));
                if (parts.length <= maxPCount) return;

                const fragment = doc.createDocumentFragment();
                for (let i = 0; i < parts.length; i += maxPCount) {
                    const chunk = parts.slice(i, i + maxPCount);
                    const newSection = doc.createElement("section");

                    for (const attr of section.attributes) {
                        newSection.setAttribute(attr.name, attr.value);
                    }

                    chunk.forEach(p => newSection.appendChild(p.cloneNode(true)));

                    newSection.setAttribute("data-split", "true");

                    fragment.appendChild(newSection);
                }

                section.parentNode.replaceChild(fragment, section);
            });

            doc.querySelectorAll('binary').forEach(bin => {
                const id = bin.getAttribute('id');
                const type = bin.getAttribute('content-type') || 'image/png';
                const data = bin.textContent.trim();
                if (id && data) imageMap.set(id, `data:${type};base64,${data}`);
            });

            doc.querySelectorAll('body[name="notes"] > section').forEach(note => {
                const id = note.getAttribute('id');
                if (id && note) noteMap.set(id, new DOMParser().parseFromString(convertNode(note, imageMap, false), 'text/html').querySelector('section').innerHTML);
            });

            const coverImg = doc.querySelector('coverpage image');
            if (coverImg) {
                const href = coverImg.getAttribute('l:href') || coverImg.getAttribute('href');
                if (href?.startsWith('#')) {
                    const src = imageMap.get(href.slice(1));
                    if (src) {
                        pages.push(`<div class="fb2-cover"><img src="${escapeHtml(src)}" class="fb2-cover-img" alt="Cover" /></div>`);
                    }
                }
            }

            const body = doc.querySelector('body');

            convertNode(body, imageMap);

            pages = pages.filter(page => page !== '')
        }

        function convertNode(node, imageMap, isPage = true) {
            if (node.nodeType === Node.TEXT_NODE) {
                return escapeHtml(node.nodeValue);
            }
            if (node.nodeType !== Node.ELEMENT_NODE) return '';

            const tag = node.localName;
            const children = () => Array.from(node.childNodes).map(n => convertNode(n, imageMap)).join('');

            switch (tag) {
                case 'p':
                    return `<p>${children()}</p>`;
                case 'cite':
                    return `<p class="cite-author">${children()}</p>`;
                case 'section':
                    if (isPage) pages.push(`<section>${children()}</section>`);
                    return `<section>${children()}</section>`;
                case 'title': {
                    const level = node.closest('section') ? 2 : 1;
                    return `<h${level}>${children()}</h${level}>`;
                }
                case 'image':
                case 'img': {
                    const href = node.getAttribute('l:href') || node.getAttribute('href') || '';
                    if (href.startsWith('#')) {
                        const src = imageMap.get(href.slice(1));
                        if (src) return `<div class="fb2-image-container"><img src="${escapeHtml(src)}" class="fb2-image" /></div>`;
                    }
                    return `<div>[Image missing: ${href}]</div>`;
                }
                case 'poem':
                    return `<div class="poem">${children()}</div>`;
                case 'v':
                    return `<div class="verse">${children()}</div>`;
                case 'empty-line':
                    return `<div>&nbsp;</div>`;
                case 'emphasis':
                    return `<em>${children()}</em>`;
                case 'strong':
                    return `<strong>${children()}</strong>`;
                case 'a':
                    if (node.getAttribute('type') === 'note') {
                        const onClickHtml = noteMap.get(node.getAttribute('l:href').replace('#', ''));
                        return `<button type="button" class="note-btn" onclick='openModalClicked(${JSON.stringify(onClickHtml)})'></button>`;
                    } else return '';
                default:
                    return children();
            }
        }

        function escapeHtml(str) {
            return str?.trim().replaceAll('\n', '').replaceAll(/[&<>"']/g, m =>
                ({'&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;'}[m])
            ) || '';
        }

        Array.from(document.getElementsByClassName("prev-page")).forEach(value => {
            value.onclick = () => {
                SetPage(--currentPage);

                Array.from(document.getElementsByClassName("next-page")).forEach(value => {
                    value.disabled = false;
                });
            };
        });

        Array.from(document.getElementsByClassName("next-page")).forEach(value => {
            value.onclick = () => {
                SetPage(++currentPage);

                Array.from(document.getElementsByClassName("prev-page")).forEach(value => {
                    value.disabled = false;
                });
            };
        });

        function SetPage(page) {
            currentPage = clamp(page, 1, maxPage);

            if (currentPage === maxPage) {
                Array.from(document.getElementsByClassName("next-page")).forEach(value => {
                    value.disabled = true;
                });
            } else if (currentPage === 1) {
                Array.from(document.getElementsByClassName("prev-page")).forEach(value => {
                    value.disabled = true;
                });
            }

            renderPage(currentPage);

            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });

            SendCurrPage();
        }

        function clamp(value, min, max) {
            return Math.min(Math.max(value, min), max);
        }

        if (@Model.SendUpdateInSeconds != null && @Model.SendUpdateInSeconds > 0)
            setInterval(SendCurrPage, (@Model.SendUpdateInSeconds - 10) * 1000);
        else setInterval(SendCurrPage, 20 * 60 * 1000);

        function SendCurrPage() {
            const currentScale = 1;

            axios.post('/api/FileApi/UpdatePage', {
                FileId: "@Model.FileId",
                UserId: "@Model.UserId",
                Page: currentPage,
                Scale: currentScale >= 1 ? currentScale : 1,
            }, {
                headers: {
                    'RequestVerificationToken': GetAntiForgeryToken()
                },
                withCredentials: true
            });
        }
    </script>
}
