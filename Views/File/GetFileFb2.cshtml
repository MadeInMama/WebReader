@model WebReader.Models.Dtos.FileViewModel

@{
    ViewData["Title"] = Model.Title;
}

@section Style
{

<link rel="stylesheet" href="~/css/file-fb2-preview.css" asp-append-version="true"/>
<style>
    .fb2-cover > img, .fb2-image-container > img {
        width: 100%;
        object-fit: cover;
        margin-left: auto;
        margin-right: auto;
        display: block;
        max-width: 50%;
    }

    .fb2-canvas-container p {
        text-align: justify;
    }
</style>
}

@section SpecialInfo

{
<h3 class="special-info-big">@Model.Title</h3>
}

<h3 class="special-info-small">@Model.Title</h3>

<div class="fb2-canvas-container"
     style="width: 100%;max-width: var(--max-width); margin-left: auto; margin-right: auto;">
</div>

