@model WebReader.Models.Dtos.AllScheduledTaskConfigsViewModel

@{
    ViewBag.Title = "Scheduled Tasks";
}

@section Style
{
    <link rel="stylesheet" href="~/css/scheduled-tasks.css" asp-append-version="true"/>
}

@section SpecialInfo
{
    @if (User.Identity is { IsAuthenticated: true })
    {
        <h3 class="special-info-big">Hello, @User.Identity.Name!</h3>
    }
}

@await Html.PartialAsync("_ModalInfoWithCustomHtml")

<form id="create-task-form">
    <div>
        <label for="options">Select Type:</label>
        <select id="options" required>
            @foreach (var item in Model.Items)
            {
                <option value="@Html.Raw(item.Id)">@item.Type</option>
            }
        </select>
    </div>

    <div>
        <label for="dateTime">Have To Start At:</label>
        <input type="datetime-local" id="dateTime" step="1" required value="">
    </div>

    <button id="submitBtn" type="submit">Confirm</button>
</form>

<div id="scheduled_tasks_partial">
</div>

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/9.0.6/signalr.min.js"
            integrity="sha512-kkMt8UThSmWcdXLYFaGZ/U6vyWSNLZMUWQ5SMeF80pGqrEkH5ei9D/3MbVQpB8p7D5C3A4vlX7BpsWTT2BfB6A=="
            crossorigin="anonymous" referrerpolicy="no-referrer"></script>

    <script>
        const rawValues = {
            "Type": null,
            "Status": null,
            "Cron": null,
        };

        const filteredValues = Object.fromEntries(
            Object.entries(rawValues)
                .filter(([_, val]) => val !== null && val !== undefined)
                .map(([key, value]) => [key, String(value)])
        );

        reload();

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/ScheduledTaskHub")
            .build();

        connection.on("ScheduledTaskHub", reload)

        connection.start()
            .then(() => {
            })
            .catch(err => console.error(err.toString()));

        function reload() {
            requestQueue.enqueue({
                method: 'POST',
                url: '/ScheduledTask/ScheduledTasksPartial',
                data: {Values: filteredValues},
                options: {
                    headers: {
                        'RequestVerificationToken': GetAntiForgeryToken()
                    },
                    withCredentials: true
                },
                beforeSend: () => {
                },
                setProgress: (val) => {
                }
            })
                .then(async response => {
                    document.getElementById('scheduled_tasks_partial').innerHTML = await response.data;
                })
                .catch(error => {
                    console.error(`Ошибка при выполнении AJAX-запроса: ${error}`);
                });
        }

        function setDefaultDateTime() {
            const now = new Date();

            const offsetMs = now.getTimezoneOffset() * 60 * 1000;

            document.getElementById('dateTime').value = new Date(now.getTime() - offsetMs).toISOString().slice(0, 19);
        }

        setDefaultDateTime();

        document.getElementById('create-task-form').onsubmit = (event) => {
            event.preventDefault();

            const form = event.target;
            const optionSelect = document.getElementById('options');
            const dateTimeInput = document.getElementById('dateTime');
            const submitBtn = document.getElementById('submitBtn');

            optionSelect.disabled = true;
            dateTimeInput.disabled = true;
            submitBtn.disabled = true;
            submitBtn.innerText = 'Sending...';

            const dateTimeOffset = new Date(dateTimeInput.value).toISOString();

            requestQueue.enqueue({
                method: 'POST',
                url: '/ScheduledTask/CreateTask',
                data: {
                    ScheduledTaskConfigId: optionSelect.value,
                    HaveToStartAt: dateTimeOffset
                },
                options: {
                    headers: {
                        'RequestVerificationToken': GetAntiForgeryToken()
                    },
                    withCredentials: true
                },
                beforeSend: () => {
                },
                setProgress: (val) => {
                }
            })
                .then(async response => {
                })
                .catch(error => {
                    console.error('Ошибка при отправке:', error);
                })
                .finally(_ => {
                    optionSelect.disabled = false;
                    dateTimeInput.disabled = false;
                    submitBtn.disabled = false;
                    setDefaultDateTime();
                    submitBtn.innerText = 'Confirm';
                });
        };
    </script>
}
